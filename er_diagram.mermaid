    float   temp_c
    float   pressure_bar
    float   reaction_time_h
    float   yield_pct
    float   lb_ratio
    float   tof_h_inv
    float   space_time_yield_g_Lh
    float   catalyst_cost_USD_kg
    float   e_factor
    float   pmi                 "process mass intensity"
    string  scale_up_challenges
    int     ref_id          FK
    date    study_date
    string  notes
}

REPRODUCIBILITY_STUDY {
    int     repro_id        PK
    int     assay_id        FK
    int     replicate_number
    float   conversion_pct
    float   yield_pct
    float   lb_ratio
    float   tof_h_inv
    float   ton
