    string  same_operator    "yes|no"
    float   std_dev_conversion
    float   std_dev_yield
    float   rsd_pct
    string  notes
}

%% ─────────────────────────────────────────
%% ANALYTICAL & CHARACTERIZATION ENTITIES
%% ─────────────────────────────────────────

CATALYST_CHARACTERIZATION {
    int     char_id         PK
    int     precatalyst_id  FK
    string  technique           "XRD|XPS|TEM|SEM|IR|NMR|ICP-MS|TGA|BET|Raman|EXAFS"
    string  instrument_model
    string  measurement_conditions
    string  key_findings
    string  data_file_path
    date    measurement_date
    int     measured_by     FK
    int     ref_id          FK
    string  notes
}

NMR_DATA {
    int     nmr_id          PK
    int     char_id         FK
    string  nucleus             "1H|13C|31P|103Rh|59Co"
    float   field_strength_MHz
    string  solvent
    float   temp_c
    string  key_shifts_ppm      "JSON list of {assignment, shift, multiplicity}"
    string  coupling_constants_Hz
    string  spectrum_file_path
    string  notes
}

IR_DATA {
    int     ir_id           PK
    int     char_id         FK
    string  technique           "ATR-IR|transmission_IR|in_situ_HP_IR"
    float   co_stretch_cm_inv
    float   rh_co_stretch_cm_inv
    string  key_bands_json
    string  spectrum_file_path
    string  notes
}

HP_IR_INSITU {
    int     hpir_id         PK
    int     assay_id        FK
    float   pressure_bar
    float   temp_c
    float   co_h2_ratio
    float   co_stretch_cm_inv
    string  active_species_assigned
    string  spectrum_file_path
    string  notes
}

%% ─────────────────────────────────────────
%% AUDIT & DATA MANAGEMENT
%% ─────────────────────────────────────────

AUDIT_LOG {
    int     log_id          PK
    string  table_name
    int     record_id
    string  action              "INSERT|UPDATE|DELETE"
    int     performed_by    FK
    timestamp action_timestamp
    string  old_values_json
    string  new_values_json
    string  ip_address
}

DATA_FILE {
    int     file_id         PK
    int     assay_id        FK
    string  file_name
    string  file_type           "GC_raw|GC_processed|NMR_raw|DFT_output|HP_IR|HPLC|image"
    string  file_path
    float   file_size_MB
    string  checksum_sha256
    date    uploaded_date
    int     uploaded_by     FK
    string  notes
}

BENCHMARK_COMPARISON {
    int     bench_id        PK
    string  benchmark_name
    int     ref_precatalyst_id  FK
    int     test_precatalyst_id FK
    int     assay_ref_id    FK
    int     assay_test_id   FK
    float   tof_improvement_pct
    float   selectivity_improvement_pct
    float   ton_improvement_pct
    float   lb_ratio_change
    string  conclusion
    int     compared_by     FK
    date    comparison_date
    string  notes
}

